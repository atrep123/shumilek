  "response": "{\n  \"files\": [\n    {\"path\":\"src/modules/projects/routes.js\",\"content\":\"import express from 'express';\\\\nimport { getProjectById } from './service.js';\\\\n\\\\nconst router = express.Router();\\\\n\\\\nrouter.get('/:projectId', async (req, res) => {\\\\n  const project = await getProjectById(req.params.projectId);\\\\n  if (!project) return sendError(res, 404, 'NotFoundError', 'Project not found');\\\\n  res.json({ project });\\\\n});\\\\n\\\\nexport default router;\\\\n\"},\n    {\"path\":\"src/modules/projects/service.js\",\"content\":\"import { randomUUID } from 'node:crypto';\\\\nimport { sendError } from '../../lib/errors.js';\\\\n\\\\nconst projects = {};\\\\n\\\\nexport const createProject = (name) => {\\\\n  if (!name) throw new Error('Name is required');\\\\n  const id = randomUUID();\\\\n  projects[id] = { id, name };\\\\n  return { id, name };\\\\n};\\\\n\\\\nexport const getProjectById = (projectId) => projects[projectId];\\\\n\"},\n    {\"path\":\"src/modules/projects/routes.js\",\"content\":\"import express from 'express';\\\\nimport { createProject, getProjectById } from './service.js';\\\\nimport { sendError } from '../../lib/errors.js';\\\\n\\\\nconst router = express.Router();\\\\n\\\\nrouter.post('/', async (req, res) => {\\\\n  try {\\\\n    const project = createProject(req.body.name);\\\\n    res.status(201).json({ project });\\\\n  } catch (error) {\\\\n    if (error.message === 'Name is required') return sendError(res, 400, 'BadRequestError', error.message);\\\\n    throw error;\\\\n  }\\\\n});\\\\n\\\\nrouter.get('/:projectId', async (req, res) => {\\\\n  const project = await getProjectById(req.params.projectId);\\\\n  if (!project) return sendError(res, 404, 'NotFoundError', 'Project not found');\\\\n  res.json({ project });\\\\n});\\\\n\\\\nexport default router;\\\\n\"},\n    {\"path\":\"src/modules/tasks/routes.js\",\"content\":\"import express from 'express';\\\\nimport { createTask, getTasksByProjectId, updateTaskStatus } from './service.js';\\\\nimport { sendError } from '../../lib/errors.js';\\\\n\\\\nconst router = express.Router({ mergeParams: true });\\\\n\\\\nrouter.post('/', async (req, res) => {\\\\n  try {\\\\n    const task = createTask(req.body.title);\\\\n    res.status(201).json({ task });\\\\n  } catch (error) {\\\\n    if (error.message === 'Title is required') return sendError(res, 400, 'BadRequestError', error.message);\\\\n    throw error;\\\\n  }\\\\n});\\\\n\\\\nrouter.get('/', async (req, res) => {\\\\n  const tasks = await getTasksByProjectId(req.params.projectId);\\\\n  if (!tasks || tasks.length === 0) return sendError(res, 404, 'NotFoundError', 'No tasks found');\\\\n  res.json({ tasks });\\\\n});\\\\n\\\\nrouter.patch('/:taskId', async (req, res) => {\\\\n  const task = await updateTaskStatus(req.params.projectId, req.params.taskId, req.body.status);\\\\n  if (!task) return sendError(res, 404, 'NotFoundError', 'Task not found');\\\\n  if (['todo', 'done'].includes(req.body.status)) {\\\\n    res.json({ task });\\\\n  } else {\\\\n    return sendError(res, 400, 'BadRequestError', 'Invalid status');\\\\n  }\\\\n});\\\\n\\\\nexport default router;\\\\n\"},\n    {\"path\":\"src/modules/tasks/service.js\",\"content\":\"import { randomUUID } from 'node:crypto';\\\\nimport { sendError } from '../../lib/errors.js';\\\\n\\\\nconst tasks = {};\\\\n\\\\nexport const createTask = (title) => {\\\\n  if (!title) throw new Error('Title is required');\\\\n  const id = randomUUID();\\\\n  tasks[id] = { id, title, status: 'todo' };\\\\n  return { id, title, status: 'todo' };\\\\n};\\\\n\\\\nexport const getTasksByProjectId = (projectId) => {\\\\n  return Object.values(tasks).filter(task => task.projectId === projectId);\\\\n};\\\\n\\\\nexport const updateTaskStatus = (projectId, taskId, status) => {\\\\n  if (!['todo', 'done'].includes(status)) throw new Error('Invalid status');\\\\n  tasks[taskId].status = status;\\\\n  return { id: taskId, title: tasks[taskId].title, status };\\\\n};\\\\n\"}\n  ],\n  \"notes\": \"Added routes for project detail and fixed validation errors.\"\n}",
