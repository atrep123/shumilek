  "response": "{\n  \"mode\": \"full\",\n  \"files\": [\n    {\"path\": \"README.md\", \"content\": \"\\n# README\\n\\nProjekt pro AI vytvořený pomocí standardních knihoven Pythonu. Obsahuje strukturu projektu s balíčkem `mini_ai` a testy.\\n\"},\n    {\"path\": \"mini_ai/__init__.py\", \"content\": \"\\nfrom .cli import cli\\nfrom .markov import MarkovChain\\n\"},\n    {\"path\": \"mini_ai/cli.py\", \"content\": \"\\nimport unittest\\nfrom mini_ai.markov import MarkovChain\\nfrom mini_ai.cli import generate, train\\n\\ndef main():\\n    parser = argparse.ArgumentParser()\\n    parser.add_argument('--train', action='store_true')\\n    parser.add_argument('--generate', action='store_true')\\n    args = parser.parse_args()\\n    if args.train:\\n        train(args)\\n    elif args.generate:\\n        generate(args)\\n\\nif __name__ == '__main__':\\n    main()\\n\"},\n    {\"path\": \"mini_ai/markov.py\", \"content\": \"\\nimport random\\nfrom collections import defaultdict\\n\\nclass MarkovChain:\\n    def __init__(self):\\n        self.chain = defaultdict(lambda: defaultdict(list))\\n\\n    def train(self, text):\\n        words = text.split()\\n        for i in range(len(words) - 1):\\n            self.chain[words[i]][words[i + 1]].append(i)\\n\\n    def generate(self, length=50):\\n        generated_text = []\\n        current_word_index = random.randint(0, len(self.chain.keys()) - 1)\\n        for _ in range(length):\\n            next_word_indices = self.chain[self.text[current_word_index]]\\n            if not next_word_indices:\\n                break\\n            next_word_index = random.choice(next_word_indices)\\n            generated_text.append(self.text[next_word_index])\\n            current_word_index = next_word_index\\n        return ''.join(generated_text)\\n\"},\n    {\"path\": \"tests/test_markov.py\", \"content\": \"\\nimport unittest\\nfrom mini_ai.markov import MarkovChain\\nfrom mini_ai.cli import cli, train, generate\\n\\nclass TestMarkovChain(unittest.TestCase):\\n    def setUp(self):\\n        self.model = MarkovChain()\\n        self.text = 'hello world'\\n        self.model.train(self.text)\\n\\n    def test_train(self):\\n        for word in self.text.split():\\n            self.assertIn(word, self.model.chain)\\n            self.assertIn(word[0], self.model.chain[word])\\n\\n    def test_generate(self):\\n        generated_text = generate(10)\\n        self.assertEqual(len(generated_text), 10)\\n        for char in generated_text:\\n            self.assertTrue(char in self.text or char == '')\\n\"},\n    {\"path\": \"tests/test_cli.py\", \"content\": \"\\nimport unittest\\nfrom mini_ai.cli import cli, train, generate\\n\\nclass TestCLI(unittest.TestCase):\\n    def setUp(self):\\n        self.model = MarkovChain()\\n        self.text = 'hello world'\\n        self.model.train(self.text)\\n\\n    def test_train(self):\\n        train(None)\\n        self.assertTrue(True)\\n\\n    def test_generate(self):\\n        generate(10)\\n        self.assertTrue(True)\\n\"}\n  ],\n  \"notes\": \"Změna v `cli.py` a přidání jednotkových testů pro kontrolu správnosti generování textu.\"\n}",
